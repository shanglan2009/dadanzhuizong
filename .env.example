# ============================================================
# IAS Platform 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ============================================================

# --- QQ 机器人推送 ---
# 是否启用 QQ 推送
QQ_ENABLE=true
# QQ 机器人 HTTP API 地址（go-cqhttp / NapCat 默认 5700）
QQ_API_BASE_URL=http://127.0.0.1:5700
# QQ 机器人 ID
QQ_BOT_ID=1905018758
# 推送目标类型: group（群聊）或 private（私聊）
QQ_TARGET_TYPE=group
# 推送目标 ID（群号 或 QQ号）
QQ_TARGET_ID=

# --- Cron 任务安全密钥 ---
# 用于保护 Vercel Cron Job 端点
CRON_SECRET=ias-cron-secret

# --- 数据源（可选）---
# 东财限流间隔（毫秒），默认 600
EM_MIN_INTERVAL=600

# --- Vercel ---
# Vercel 部署后自动设置，本地不需要填
# VERCEL_URL=your-app.vercel.app
